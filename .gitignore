# .NET build output
bin/
obj/
[Bb]in/
[Oo]bj/

# audit artifacts (generated SARIF, dossiers, binlogs)
artifacts/*
!artifacts/.gitkeep

# IDE
.vs/
.idea/
*.user

# NOTE: STS worktrees + the analyzer cache live OUTSIDE this repo by design
# (C:\Repos\_ownaudit\...), so the audit never dirties OwnAudit or STS git status.

# python bytecode
__pycache__/
*.pyc

# viz generated/vendored artifacts (reproducible via viz/build_dashboard.py)
viz/plotly.min.js
viz/sts-dashboard.html
viz/preview.png
viz/theme-*.png

# Own.NET Auditor — generated report artifacts
report/out/
report/out-*/

# Own.NET Auditor — user-managed baseline (large; created on the stand)
sts_audit/baseline.json

# leakmine mining run outputs (generated; corpus.db / dataset.json / summary.md)
leakmine-out/
bq-out/
ch-out/
*-leakmine-out/

.direnv/

# 007-style scratch files: Claude writes the commit message / PR body here, the user
# commits & pushes by hand (signed). Not committed.
/.commit-msg
/.pr-body.md