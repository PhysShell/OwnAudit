                ]
              }
            },
            {
              "id": "MSTEST0023",
              "shortDescription": {
                "text": "Не отрицать логические утверждения"
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0023",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,002",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0024",
              "shortDescription": {
                "text": "Не хранить TestContext в статическом элементе"
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0024",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "<0,001",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0025",
              "shortDescription": {
                "text": "Используйте \"Assert.Fail\" вместо утверждения с постоянным сбоем"
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0025",
              "properties": {
                "category": "Design",
                "executionTimeInSeconds": "0,003",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0026",
              "shortDescription": {
                "text": "Избегайте условного доступа в утверждениях"
              },
              "defaultConfiguration": {
                "level": "note",
                "enabled": false
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0026",
              "properties": {
                "category": "Usage",
                "isEverSuppressed": "true",
                "suppressionKinds": [
                  "external"
                ],
                "executionTimeInSeconds": "<0,001",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0029",
              "shortDescription": {
                "text": "Общедоступные методы должны быть тестовыми методами"
              },
              "fullDescription": {
                "text": "Общедоступные методы должны быть тестовыми методами (помеченными как \"[TestMethod]\")."
              },
              "defaultConfiguration": {
                "level": "note",
                "enabled": false
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0029",
              "properties": {
                "category": "Design",
                "isEverSuppressed": "true",
                "suppressionKinds": [
                  "external"
                ],
                "executionTimeInSeconds": "<0,001",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0030",
              "shortDescription": {
                "text": "У типа, содержащего \"[TestMethod]\", должна быть пометка \"[TestClass]\""
              },
              "fullDescription": {
                "text": "У типа, содержащего \"[TestMethod]\", должна быть пометка \"[TestClass]\", иначе метод тестирования будет проигнорирован без уведомления пользователя."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0030",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "<0,001",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0031",
              "shortDescription": {
                "text": "\"System.ComponentModel.DescriptionAttribute\" не действует на методы тестирования"
              },
              "fullDescription": {
                "text": "\"System.ComponentModel.DescriptionAttribute\" не действует в контексте тестов. Вероятно, вы хотели использовать \"Microsoft.VisualStudio.TestTools.UnitTesting.DescriptionAttribute\"."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0031",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "<0,001",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0032",
              "shortDescription": {
                "text": "Условие проверочного утверждения всегда истинно"
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0032",
              "properties": {
                "category": "Design",
                "executionTimeInSeconds": "0,003",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0034",
              "shortDescription": {
                "text": "Использовать \"classCleanupBehavior.EndOfClass\" с \"[ClassCleanup]\""
              },
              "fullDescription": {
                "text": "Без использования \"ClassCleanupBehavior.EndOfClass\" \"[ClassCleanup]\" по умолчанию будет выполняться в конце сборки, а не в конце класса."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0034",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,003",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0035",
              "shortDescription": {
                "text": "Указать \"[DeploymentItem]\" можно только для тестового класса или метода."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0035",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,002",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0036",
              "shortDescription": {
                "text": "Не используйте удаленное управление"
              },
              "fullDescription": {
                "text": "Удаленное управление элементами теста может вызвать проблемы с тестированием (например, NRE)."
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0036",
              "properties": {
                "category": "Design",
                "executionTimeInSeconds": "<0,001",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0037",
              "shortDescription": {
                "text": "Используйте правильные методы \"Assert\""
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0037",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,008",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0038",
              "shortDescription": {
                "text": "Не используйте Assert.AreSame или Assert.AreNotSame с типами значений"
              },
              "fullDescription": {
                "text": "При сравнении типов значений используйте \"Assert.AreEqual\"/\"Assert.AreNotEqual\" вместо \"Assert.AreSame\"/\"Assert.AreNotSame\". Передача типа значения в \"Assert.AreSame\"/\"Assert.AreNotSame\" будет добавлена в рамку (создание нового объекта). Поскольку \"Assert.AreSame\"/\"Assert.AreNotSame\" выполняет сравнение по ссылке, при боксе \"Assert.AreSame\" будет выполняться с ошибкой, а \"Assert.AreNotSame\" всегда будет проходить."
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0038",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,002",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0039",
              "shortDescription": {
                "text": "Использовать более новые методы для утверждения исключений"
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0039",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,002",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0040",
              "shortDescription": {
                "text": "Не утверждать внутри контекстов async void"
              },
              "fullDescription": {
                "text": "Не подтверяйте внутри методов async void, локальных функций или лямбда-выражений. Исключения, вызванные в этом контексте, будут необработанные исключения. При использовании VSTest платформа .NET Framework, они будут пропущены без уведомления. При использовании Microsoft.Testing.Platform или VSTest в современной версии .NET они могут привести к сбою процесса."
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0040",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,002",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0041",
              "shortDescription": {
                "text": "Использовать ConditionBaseAttribute для тестовых классов"
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0041",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "<0,001",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0042",
              "shortDescription": {
                "text": "Избегайте дублирования записей \"DataRow\""
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0042",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "<0,001",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0043",
              "shortDescription": {
                "text": "Использовать атрибут retry в тестовом методе"
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0043",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,001",
                "executionTimeInPercentage": "<1",
                "tags": [
                  "EscalateToErrorInRecommended"
                ]
              }
            },
            {
              "id": "MSTEST0044",
              "shortDescription": {
                "text": "Следует предпочитать метод \"TestMethod\" методу \"DataTestMethod\""
              },
              "fullDescription": {
                "text": "Атрибут \"DataTestMethodAttribute\" устарел и не предоставляет дополнительных функций по сравнению с \"TestMethodAttribute\". Используйте '\"TestMethodAttribute\" для всех методов тестирования, включая параметризованные тесты."
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0044",
              "properties": {
                "category": "Design",
                "executionTimeInSeconds": "<0,001",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0045",
              "shortDescription": {
                "text": "Использовать \"CooperativeCancellation = true\" с \"[Timeout]\""
              },
              "fullDescription": {
                "text": "Использование \"[Timeout]\" без явной настройки \"CooperativeCancellation = true\" не рекомендуется. В будущей версии кооперативная отмена станет поведением по умолчанию. Настройте \"CooperativeCancellation = true\", чтобы согласиться с рекомендуемым поведением и избежать критических изменений."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0045",
              "properties": {
                "category": "Design",
                "executionTimeInSeconds": "<0,001",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0046",
              "shortDescription": {
                "text": "Используйте \"Assert\" вместо \"StringAssert\""
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0046",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,002",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0048",
              "shortDescription": {
                "text": "Свойство TestContext недоступно в этом контексте"
              },
              "fullDescription": {
                "text": "Некоторые свойства TestContext доступны только во время выполнения теста и недоступны в методах инициализации сборки, инициализации класса, очистки класса или очистки сборки."
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0048",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,003",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0049",
              "shortDescription": {
                "text": "Передача TestContext.CancellationToken в асинхронные операции"
              },
              "fullDescription": {
                "text": "При вызове асинхронных методов с перегрузками, принимающими параметр CancellationToken, рекомендуется использовать перегрузку с TestContext.CancellationTokenSource.Token, чтобы обеспечить кооперативную отмену и учитывать времена ожидания теста."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0049",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,019",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0050",
              "shortDescription": {
                "text": "GlobalTestInitialize and GlobalTestCleanup methods should have valid layout"
              },
              "fullDescription": {
                "text": "Methods marked with '[GlobalTestInitialize]' or '[GlobalTestCleanup]' should follow the following layout to be valid:\u000d\u000a-it can't be declared on a generic class\u000d\u000a-it should be 'public'\u000d\u000a-it should be 'static'\u000d\u000a-it should not be 'async void'\u000d\u000a-it should not be a special method (finalizer, operator...).\u000d\u000a-it should not be generic\u000d\u000a-it should take one parameter of type 'TestContext'\u000d\u000a-return type should be 'void', 'Task' or 'ValueTask'\u000d\u000a\u000d\u000aThe type declaring these methods should also respect the following rules:\u000d\u000a-The type should be a class\u000d\u000a-The class should be 'public'\u000d\u000a-The class shouldn't be 'static'\u000d\u000a-The class should be marked with '[TestClass]' (or a derived attribute)\u000d\u000a-the class should not be generic."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0050",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "<0,001",
                "executionTimeInPercentage": "<1"
              }
            },
