                ]
              }
            },
            {
              "id": "MSTEST0022",
              "shortDescription": {
                "text": "Предпочитать TestCleanup методам \"Dispose\""
              },
              "defaultConfiguration": {
                "level": "note",
                "enabled": false
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0022",
