            },
            {
              "id": "AsyncFixer01",
              "shortDescription": {
                "text": "Unnecessary async/await usage"
              },
              "fullDescription": {
                "text": "When a method only awaits a single expression as its last statement and returns the result, the async/await keywords add unnecessary overhead. Return the Task directly and let the caller await it. This reduces state machine allocation and improves performance. Exception: Keep async/await when you need try/catch around the await or when the method has multiple awaits."
              },
              "helpUri": "https://github.com/semihokur/AsyncFixer#asyncfixer01",
              "properties": {
                "category": "AsyncUsage",
                "executionTimeInSeconds": "<0,001",
                "executionTimeInPercentage": "<1",
                "tags": [
                  "Telemetry"
                ]
              }
            },
            {
              "id": "AsyncFixer02",
              "shortDescription": {
                "text": "Blocking call inside an async method"
              },
              "fullDescription": {
                "text": "Blocking calls like Task.Result, Task.Wait(), Thread.Sleep(), or Task.GetAwaiter().GetResult() inside async methods can cause deadlocks, especially in UI or ASP.NET contexts with synchronization contexts. Use the async equivalents: await instead of .Result/.Wait(), Task.Delay() instead of Thread.Sleep(), Task.WhenAll() instead of Task.WaitAll()."
              },
              "helpUri": "https://github.com/semihokur/AsyncFixer#asyncfixer02",
              "properties": {
                "category": "AsyncUsage",
                "executionTimeInSeconds": "0,002",
                "executionTimeInPercentage": "<1",
                "tags": [
                  "Telemetry"
                ]
              }
            },
            {
              "id": "AsyncFixer03",
              "shortDescription": {
                "text": "Fire-and-forget async-void methods or delegates"
              },
              "fullDescription": {
                "text": "Async void methods cannot be awaited, making it impossible to know when they complete or to catch their exceptions. Exceptions thrown in async void methods will crash the process. Use 'async Task' instead, which allows proper exception handling and await support. The only valid use case for async void is event handlers."
              },
              "helpUri": "https://github.com/semihokur/AsyncFixer#asyncfixer03",
              "properties": {
                "category": "AsyncUsage",
                "executionTimeInSeconds": "0,003",
                "executionTimeInPercentage": "<1",
                "tags": [
                  "Telemetry"
                ]
              }
            },
            {
              "id": "AsyncFixer04",
              "shortDescription": {
                "text": "Fire-and-forget async call inside a using block"
              },
              "fullDescription": {
                "text": "When an async method is called without await inside a using block, the disposable resource may be disposed before the async operation completes, causing exceptions or undefined behavior. Always await async calls that depend on resources in the using scope."
              },
              "helpUri": "https://github.com/semihokur/AsyncFixer#asyncfixer04",
              "properties": {
                "category": "AsyncUsage",
                "executionTimeInSeconds": "0,002",
                "executionTimeInPercentage": "<1",
                "tags": [
                  "Telemetry"
                ]
              }
            },
            {
              "id": "AsyncFixer05",
              "shortDescription": {
                "text": "Nested Task<Task> from TaskFactory.StartNew with async lambda"
              },
              "fullDescription": {
                "text": "Using TaskFactory.StartNew() with an async lambda creates a Task<Task> (nested task). Awaiting only the outer task doesn't wait for the inner async operation to complete. Use Task.Run() instead, which automatically unwraps async lambdas, or call .Unwrap() on the result."
              },
              "helpUri": "https://github.com/semihokur/AsyncFixer#asyncfixer05",
              "properties": {
                "category": "AsyncUsage",
                "executionTimeInSeconds": "0,066",
                "executionTimeInPercentage": "1",
                "tags": [
                  "Telemetry"
                ]
              }
            },
            {
              "id": "AsyncFixer06",
              "shortDescription": {
                "text": "Task<T> to Task conversion silently discards result"
              },
              "fullDescription": {
                "text": "A non-async lambda returning Task<T> is being assigned to a delegate expecting Task (e.g., Func<Task>). The result value is silently discarded due to implicit conversion from Task<T> to Task. Unlike async lambdas which produce compiler error CS8031 for this pattern, non-async lambdas compile without warning. Either change the delegate type to Func<Task<T>> to preserve the result, or explicitly discard it if intentional."
              },
              "helpUri": "https://github.com/semihokur/AsyncFixer#asyncfixer06",
              "properties": {
                "category": "AsyncUsage",
                "executionTimeInSeconds": "0,039",
                "executionTimeInPercentage": "<1",
                "tags": [
                  "Telemetry"
                ]
              }
            },
            {
              "id": "IDISP001",
              "shortDescription": {
                "text": "Dispose created"
              },
              "fullDescription": {
                "text": "When you create an instance of a type that implements IDisposable you are responsible for disposing it."
              },
              "helpUri": "https://github.com/DotNetAnalyzers/IDisposableAnalyzers/blob/master/documentation/IDISP001.md",
