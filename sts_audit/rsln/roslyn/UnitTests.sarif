              }
            },
            {
              "id": "MsgPack001",
              "shortDescription": {
                "text": "Avoid mutable default options"
              },
              "fullDescription": {
                "text": "Without an explicit MessagePackSerializerOptions argument, a shared/static default will be assumed which any other code in the entire AppDomain or process can alter, causing malfunction in your invocation."
              },
              "defaultConfiguration": {
                "enabled": false
              },
              "helpUri": "https://github.com/MessagePack-CSharp/MessagePack-CSharp/blob/master/doc/analyzers/MsgPack001.md",
              "properties": {
                "category": "Reliability",
                "isEverSuppressed": "true",
                "suppressionKinds": [
                  "external"
                ],
                "executionTimeInSeconds": "<0,001",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MsgPack002",
              "shortDescription": {
                "text": "Avoid mutable static options"
              },
              "fullDescription": {
                "text": "Providing a static value for MessagePackSerializerOptions from a mutable member can lead to malfunction when that member is mutated by another party."
              },
              "defaultConfiguration": {
                "enabled": false
              },
              "helpUri": "https://github.com/MessagePack-CSharp/MessagePack-CSharp/blob/master/doc/analyzers/MsgPack002.md",
              "properties": {
                "category": "Reliability",
                "isEverSuppressed": "true",
                "suppressionKinds": [
                  "external"
                ],
                "executionTimeInSeconds": "<0,001",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MsgPack003",
              "shortDescription": {
                "text": "Use MessagePackObjectAttribute"
              },
              "fullDescription": {
                "text": "Type must be marked with MessagePackObjectAttribute."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "https://github.com/MessagePack-CSharp/MessagePack-CSharp/blob/master/doc/analyzers/MsgPack003.md",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,005",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MsgPack004",
              "shortDescription": {
                "text": "Attribute properties and fields of MessagePack objects"
              },
              "fullDescription": {
                "text": "Member must be marked with KeyAttribute or IgnoreMemberAttribute."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "https://github.com/MessagePack-CSharp/MessagePack-CSharp/blob/master/doc/analyzers/MsgPack004.md",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,005",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MsgPack005",
              "shortDescription": {
                "text": "MessagePackObject validation"
              },
              "fullDescription": {
                "text": "Invalid MessagePackObject definition."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "https://github.com/MessagePack-CSharp/MessagePack-CSharp/blob/master/doc/analyzers/MsgPack005.md",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,005",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MsgPack006",
              "shortDescription": {
                "text": "Must be IMessageFormatter"
              },
              "fullDescription": {
                "text": "Type must be of IMessagePackFormatter."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "https://github.com/MessagePack-CSharp/MessagePack-CSharp/blob/master/doc/analyzers/MsgPack006.md",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,005",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MsgPack007",
              "shortDescription": {
                "text": "Deserializing constructors"
              },
              "fullDescription": {
                "text": "A deserializable type must carry a public constructor."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "https://github.com/MessagePack-CSharp/MessagePack-CSharp/blob/master/doc/analyzers/MsgPack007.md",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,005",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MsgPack008",
              "shortDescription": {
                "text": "AOT limitations"
              },
              "fullDescription": {
                "text": "Use a type argument with UnionAttribute."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "https://github.com/MessagePack-CSharp/MessagePack-CSharp/blob/master/doc/analyzers/MsgPack008.md",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,005",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MsgPack009",
              "shortDescription": {
                "text": "Colliding formatters"
              },
              "fullDescription": {
                "text": "Only one formatter per type is allowed."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "https://github.com/MessagePack-CSharp/MessagePack-CSharp/blob/master/doc/analyzers/MsgPack009.md",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,005",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MsgPack010",
              "shortDescription": {
                "text": "Inaccessible formatter"
              },
              "fullDescription": {
                "text": "The auto-generated resolver cannot access this formatter. It will be omitted from the resolver."
              },
              "helpUri": "https://github.com/MessagePack-CSharp/MessagePack-CSharp/blob/master/doc/analyzers/MsgPack010.md",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,005",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MsgPack011",
              "shortDescription": {
                "text": "Partial type required"
              },
              "fullDescription": {
                "text": "When a data type has serializable members that may only be accessible to the class itself (e.g. private or protected members), the type must be declared as partial to allow source generation of the formatter as a nested type. When a data type is itself a nested type, its declaring types must also be partial."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "https://github.com/MessagePack-CSharp/MessagePack-CSharp/blob/master/doc/analyzers/MsgPack011.md",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,005",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MsgPack012",
              "shortDescription": {
                "text": "Internally accessible data type required"
              },
              "fullDescription": {
                "text": "MessagePack serializable objects must be at least internally accessible so a source-generated formatter can access it."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "https://github.com/MessagePack-CSharp/MessagePack-CSharp/blob/master/doc/analyzers/MsgPack012.md",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,005",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MsgPack013",
              "shortDescription": {
                "text": "Inaccessible formatter"
              },
              "fullDescription": {
                "text": "The auto-generated resolver cannot construct this formatter without a constructor. It will be omitted from the resolver."
              },
              "helpUri": "https://github.com/MessagePack-CSharp/MessagePack-CSharp/blob/master/doc/analyzers/MsgPack013.md",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,005",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MsgPack014",
              "shortDescription": {
                "text": "Format nullable reference types"
              },
              "helpUri": "https://github.com/MessagePack-CSharp/MessagePack-CSharp/blob/master/doc/analyzers/MsgPack014.md",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,005",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MsgPack015",
              "shortDescription": {
                "text": "MessagePackObjectAttribute.AllowPrivate should be set"
              },
              "helpUri": "https://github.com/MessagePack-CSharp/MessagePack-CSharp/blob/master/doc/analyzers/MsgPack015.md",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,005",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MsgPack016",
              "shortDescription": {
                "text": "KeyAttribute derivatives"
              },
              "fullDescription": {
                "text": "Use [Key(x)] attributes directly, or switch off source generation for this type using [MessagePackObject(SuppressSourceGeneration = true)]."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "https://github.com/MessagePack-CSharp/MessagePack-CSharp/blob/master/doc/analyzers/MsgPack016.md",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,005",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MsgPack017",
              "shortDescription": {
                "text": "Property with init accessor and initializer"
              },
              "fullDescription": {
                "text": "Due to a limitation in the C# language, properties with init accessor must be set by source generated deserializers unconditionally. When the data stream lacks a value for the property, it will be set with the default value for the property type, overriding a default that an initializer might set."
              },
              "helpUri": "https://github.com/MessagePack-CSharp/MessagePack-CSharp/blob/master/doc/analyzers/MsgPack017.md",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,005",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MsgPack018",
              "shortDescription": {
                "text": "Unique names required in force map mode"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "https://github.com/MessagePack-CSharp/MessagePack-CSharp/blob/master/doc/analyzers/MsgPack018.md",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,005",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0001",
              "shortDescription": {
                "text": "Явное включение или отключение параллелизации тестов"
              },
              "fullDescription": {
                "text": "По умолчанию MSTest выполняет тесты в одной сборке последовательно, что может привести к серьезному ограничению производительности. Рекомендуется включить атрибут сборки \"[Parallelize]\", чтобы выполнять тесты параллельно, или явно использовать атрибут уровня сборки \"[DoNotParallelize]\", если известно, что сборка не поддерживает параллелизацию."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0001",
              "properties": {
                "category": "Performance",
                "executionTimeInSeconds": "0,008",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0002",
              "shortDescription": {
                "text": "Тестовые классы должны использовать допустимую структуру"
              },
              "fullDescription": {
                "text": "В тестовых классах (с атрибутом \"[TestClass]\") должна быть следующая структура, чтобы эти классы считались допустимыми для MSTest:\u000d\u000a- у класса должно быть свойство \"public\" (или \"internal\", если задан атрибут \"[assembly: DiscoverInternals]\")\u000d\u000a- у класс не должно быть свойства \"static\" (кроме случаев, когда класс содержит только методы \"AssemblyInitialize\" и \"AssemblyCleanup\")\u000d\u000a- класс не должен быть универсальным."
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0002",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,019",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0003",
              "shortDescription": {
                "text": "Методы теста должны использовать допустимую структуру"
              },
              "fullDescription": {
                "text": "Методы теста (методы, помеченные атрибутом \"[TestMethod]\") должны соблюдать следующую структуру, чтобы считаться допустимыми в MSTest:\u000d\u000a– должно быть присвоено значение \"public\" (или \"internal\", если задан атрибут \"[assembly: DiscoverInternals]\")\u000d\u000a– не следует присваивать значение \"static\"\u000d\u000a– могут быть универсальными, если можно вывести параметры типа, а типы аргументов являются совместимыми\u000d\u000a– не следует присваивать значение \"abstract\"\u000d\u000a– возвращаемый тип должен быть \"void\", \"Task\" или \"ValueTask\"\u000d\u000a– не следует присваивать значение \"async void\"\u000d\u000a– это должен быть специальный метод (метод завершения, оператор...)."
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0003",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,044",
                "executionTimeInPercentage": "<1",
                "tags": [
                  "EscalateToErrorInRecommended"
                ]
              }
            },
            {
              "id": "MSTEST0004",
              "shortDescription": {
                "text": "Общедоступные типы должны быть тестовыми классами"
              },
              "fullDescription": {
                "text": "Рекомендуется использовать только тестовые классы, помеченные как общедоступные в тестовом проекте."
              },
              "defaultConfiguration": {
                "level": "note",
                "enabled": false
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0004",
              "properties": {
                "category": "Design",
                "isEverSuppressed": "true",
                "suppressionKinds": [
                  "external"
                ],
                "executionTimeInSeconds": "<0,001",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0005",
              "shortDescription": {
                "text": "Тестовое контекстное свойство должно использовать допустимый макет"
              },
              "fullDescription": {
                "text": "\"TestContext\" должно быть нестатическим полем или свойством, присваиваемым в конструкторе, или — для свойства, установленного MSTest — должно следовать набору правил:\u000d\u000a— оно должно быть объявлено как \"public\", независимо от того, задан ли атрибут \"[assembly: DiscoverInternals]\";\u000d\u000a— оно не может быть объявлено как \"static\";\u000d\u000a— для него должен быть определен метод задания."
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0005",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,029",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0006",
              "shortDescription": {
                "text": "Избегать \"[ExpectedException]\""
              },
              "fullDescription": {
                "text": "Предпочтите \"Assert.ThrowsExactly' или 'Assert.ThrowsExactlyAsync\" вместо \"[ExpectedException]\", так как это гарантирует, что только ожидаемый вызов вызовет ожидаемое исключение. API-интерфейсы утверждения также обеспечивают дополнительную гибкость и позволяют утверждать дополнительные свойства исключения."
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0006",
              "properties": {
                "category": "Design",
                "executionTimeInSeconds": "0,029",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0007",
              "shortDescription": {
                "text": "[Owner] можно задать только для методов с пометкой [TestMethod]"
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0007",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,015",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0008",
              "shortDescription": {
                "text": "Метод TestInitialize должен использовать допустимый макет"
              },
              "fullDescription": {
                "text": "Чтобы метод, помеченный \"[TestInitialize]\", был допустимым, он должен соответствовать следующим правилам:\u000d\u000a– быть общедоступным (\"public\")\u000d\u000a;\u000d\u000a– не быть абстрактным (\"abstract\")\u000d\u000a;\u000d\u000a– не быть асинхронным и не возвращающим значения (\"async void\")\u000d\u000a– не быть статическим (\"static\")\u000d\u000a– не быть специальным (метод завершения, оператор…).\u000d\u000a– не быть общим (\"generic\")\u000d\u000a;\u000d\u000a– не принимать никаких параметров;\u000d\u000a– тип возвращаемого значения должен быть \"void\", \"Task\" или \"ValueTask\";\u000d\u000a\u000d\u000aТип, объявляющий такие методы, также должен соответствовать следующим правилам:\u000d\u000a– должен быть классом;\u000d\u000a– класс должен быть объявлен как \"public\" или \"internal\" (если тестовый проект использует атрибут \"[DiscoverInternals]\");\u000d\u000a– не должен быть статическим (\"static\");\u000d\u000a– если класс запечатанный, его следует пометить как \"[TestClass]\" (или производный атрибут)."
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0008",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,013",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0009",
              "shortDescription": {
                "text": "Метод TestCleanup должен использовать допустимый макет"
              },
              "fullDescription": {
                "text": "Чтобы метод, помеченный \"[TestCleanup]\", был допустимым, он должен соответствовать следующим правилам:\u000d\u000a– быть общедоступным (\"public\")\u000d\u000a;\u000d\u000a– не быть абстрактным (\"abstract\")\u000d\u000a;\u000d\u000a– не быть асинхронным и не возвращающим значения (\"async void\")\u000d\u000a– не быть статическим (\"static\")\u000d\u000a– не быть специальным (метод завершения, оператор…).\u000d\u000a– не быть общим (\"generic\")\u000d\u000a;\u000d\u000a– не принимать никаких параметров;\u000d\u000a– тип возвращаемого значения должен быть \"void\", \"Task\" или \"ValueTask\";\u000d\u000a\u000d\u000aТип, объявляющий такие методы, также должен соответствовать следующим правилам:\u000d\u000a– должен быть классом;\u000d\u000a– класс должен быть объявлен как \"public\" или \"internal\" (если тестовый проект использует атрибут \"[DiscoverInternals]\");\u000d\u000a– не должен быть статическим (\"static\");\u000d\u000a– если класс запечатанный, его следует пометить как \"[TestClass]\" (или производный атрибут)."
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0009",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,007",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0010",
              "shortDescription": {
                "text": "Методы ClassInitialize должны использовать допустимый макет"
              },
              "fullDescription": {
                "text": "Чтобы метод, помеченный \"[ClassInitialize]\", был допустимым, он должен соответствовать следующим правилам:\u000d\u000a– не может быть объявлен для универсального класса, если не установлен режим InheritanceBehavior;\u000d\u000a– должен быть общедоступным (\"public\");\u000d\u000a– должен быть статическим (\"static\");\u000d\u000a– не быть асинхронным и не возвращающим значения (\"async void\")\u000d\u000a– не быть специальным (метод завершения, оператор…).\u000d\u000a– не быть общим (\"generic\")\u000d\u000a;\u000d\u000a– должен принимать один параметр типа \"TestContext\";\u000d\u000a– тип возвращаемого значения должен быть \"void\", \"Task\" или \"ValueTask\";\u000d\u000a– если класс абстрактный, должен быть указан параметр атрибута \"InheritanceBehavior.BeforeEachDerivedClass\";\u000d\u000a– если класс запечатанный, не следует указывать параметр атрибута \"InheritanceBehavior.BeforeEachDerivedClass\";\u000d\u000a\u000d\u000aТип, объявляющий такие методы, также должен соответствовать следующим правилам:\u000d\u000a– должен быть классом;\u000d\u000a– класс должен быть объявлен как \"public\" или \"internal\" (если тестовый проект использует атрибут \"[DiscoverInternals]\");\u000d\u000a– не должен быть объявлен как статический (\"static\");\u000d\u000a– если класс запечатанный, его следует пометить как \"[TestClass]\" (или производный атрибут);\u000d\u000a– не должен быть универсальным (\"generic\")."
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0010",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,019",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0011",
              "shortDescription": {
                "text": "Методы ClassCleanup должны использовать допустимый макет"
              },
              "fullDescription": {
                "text": "Чтобы метод, помеченный \"[ClassCleanup]\", был допустимым, он должен соответствовать следующим правилам:\u000d\u000a– не может быть объявлен для универсального класса, если не установлен режим InheritanceBehavior;\u000d\u000a– должен быть общедоступным (\"public\");\u000d\u000a– должен быть статическим (\"static\");\u000d\u000a– не должен быть асинхронным и не возвращающим значения (\"async void\")\u000d\u000a– не должен быть специальным (метод завершения, оператор…).\u000d\u000a– не должен быть общим (\"generic\")\u000d\u000a;\u000d\u000a– не должен принимать никаких параметров или должен принимать один параметр типа TestContext\u000d\u000a;\u000d\u000a– должен иметь тип возвращаемого значения \"void\", \"Task\" или \"ValueTask\";\u000d\u000a– если класс абстрактный, должен быть указан параметр атрибута \"InheritanceBehavior.BeforeEachDerivedClass\";\u000d\u000a– если класс запечатанный, не следует указывать параметр атрибута \"InheritanceBehavior.BeforeEachDerivedClass\";\u000d\u000a\u000d\u000aТип, объявляющий такие методы, также должен соответствовать следующим правилам:\u000d\u000a– должен быть классом;\u000d\u000a– класс должен быть объявлен как \"public\" или \"internal\" (если тестовый проект использует атрибут \"[DiscoverInternals]\");\u000d\u000a– не должен быть объявлен как статический (\"static\");\u000d\u000a– если класс запечатанный, его следует пометить как \"[TestClass]\" (или производный атрибут);\u000d\u000a– не должен быть универсальным (\"generic\")."
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0011",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,017",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0012",
              "shortDescription": {
                "text": "Методы AssemblyInitialize должны использовать допустимый макет"
              },
              "fullDescription": {
                "text": "Чтобы метод, помеченный \"[AssemblyInitialize]\", был допустимым, он должен соответствовать следующим правилам:\u000d\u000a– не может быть объявлен для универсального класса (\"generic\");\u000d\u000a– должен быть общедоступным (\"public\");\u000d\u000a– должен быть статическим (\"static\");\u000d\u000a– не быть асинхронным и не возвращающим значения (\"async void\")\u000d\u000a– не быть специальным (метод завершения, оператор…).\u000d\u000a– не быть общим (\"generic\")\u000d\u000a;\u000d\u000a– должен принимать один параметр типа \"TestContext\";\u000d\u000a– тип возвращаемого значения должен быть \"void\", \"Task\" или \"ValueTask\";\u000d\u000a\u000d\u000aТип, объявляющий такие методы, также должен соответствовать следующим правилам:\u000d\u000a– должен быть классом;\u000d\u000a– класс должен быть объявлен как \"public\" или \"internal\" (если тестовый проект использует атрибут \"[DiscoverInternals]\");\u000d\u000a– не должен быть статическим (\"static\");\u000d\u000a– должен быть помечен как \"[TestClass]\" (или производный атрибут);\u000d\u000a– не должен быть универсальным (\"generic\")."
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0012",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,020",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0013",
              "shortDescription": {
                "text": "Методы AssemblyCleanup должны использовать допустимый макет"
              },
              "fullDescription": {
                "text": "Чтобы метод, помеченный \"[AssemblyCleanup]\", был допустимым, он должен соответствовать следующим правилам:\u000d\u000a– не может быть объявлен для универсального класса (\"generic\");\u000d\u000a– должен быть общедоступным (\"public\");\u000d\u000a– должен быть статическим (\"static\");\u000d\u000a– не должен быть асинхронным и не возвращающим значения (\"async void\")\u000d\u000a– не должен быть специальным (метод завершения, оператор…).\u000d\u000a– не должен быть общим (\"generic\")\u000d\u000a;\u000d\u000a– не должен принимать никаких параметров или должен принимать один параметр типа TestContext\u000d\u000a;\u000d\u000a– должен иметь тип возвращаемого значения \"void\", \"Task\" или \"ValueTask\";\u000d\u000a\u000d\u000aТип, объявляющий такие методы, также должен соответствовать следующим правилам:\u000d\u000a– должен быть классом;\u000d\u000a– класс должен быть объявлен как \"public\" или \"internal\" (если тестовый проект использует атрибут \"[DiscoverInternals]\");\u000d\u000a– не должен быть статическим (\"static\");\u000d\u000a– должен быть помечен как \"[TestClass]\" (или производный атрибут);\u000d\u000a– не должен быть универсальным (\"generic\")."
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0013",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,091",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0014",
              "shortDescription": {
                "text": "Значение DataRow должно быть допустимым"
              },
              "fullDescription": {
                "text": "Действительная запись DataRow должна иметь следующую структуру:\u000d\u000a– должна быть задана только для метода теста;\u000d\u000a– количество аргументов должно совпадать с количеством аргументов метода;\u000d\u000a– тип аргумента должен совпадать с типом аргумента метода."
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0014",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,035",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0015",
              "shortDescription": {
                "text": "Метод теста не должен игнорироваться"
              },
              "fullDescription": {
                "text": "Методы теста не должны игнорироваться (помечаться с помощью \"[Ignore]\")."
              },
              "defaultConfiguration": {
                "level": "note",
                "enabled": false
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0015",
              "properties": {
                "category": "Design",
                "isEverSuppressed": "true",
                "suppressionKinds": [
                  "external"
                ],
                "executionTimeInSeconds": "<0,001",
                "executionTimeInPercentage": "<1",
                "tags": [
                  "DisableInAllMode"
                ]
              }
            },
            {
              "id": "MSTEST0016",
              "shortDescription": {
                "text": "Тестовый класс должен содержать тестовый метод"
              },
              "fullDescription": {
                "text": "Тестовый класс должен содержать хотя бы один тестовый метод или быть \"статическим\" с методами, отмеченными \"[AssemblyInitialize]\" и (или) \"[AssemblyCleanup]\"."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0016",
              "properties": {
                "category": "Design",
                "executionTimeInSeconds": "0,028",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0017",
              "shortDescription": {
                "text": "Аргументы проверочных утверждений должны передаваться в правильном порядке"
              },
              "fullDescription": {
                "text": "\"Assert.AreEqual\", \"Assert.AreNotEqual\", \"Assert.AreSame\" и \"Assert.AreNotSame\" ожидают, что сначала будет передано ожидаемое значение, а фактическое значение будет передано в качестве второго аргумента."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0017",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,013",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "MSTEST0018",
              "shortDescription": {
                "text": "Значение DynamicData должно быть допустимым"
              },
              "fullDescription": {
                "text": "Запись \"DynamicData\" должна соответствовать следующему макету, чтобы быть допустимой:\u000d\u000a– должна быть задана только для метода теста;\u000d\u000a– элемент должен быть определен в указанном типе;\u000d\u000a– элемент должен быть методом, если указан DynamicDataSourceType.Method, в противном случае он должен быть свойством."
              },
              "helpUri": "https://learn.microsoft.com/dotnet/core/testing/mstest-analyzers/mstest0018",
              "properties": {
                "category": "Usage",
                "executionTimeInSeconds": "0,012",
                "executionTimeInPercentage": "<1"
              }
            },
