            {
              "id": "MA0208",
              "shortDescription": {
                "text": "[FixedAddressValueType] fields must be value types"
              },
              "helpUri": "https://github.com/meziantou/Meziantou.Analyzer/blob/main/docs/Rules/MA0208.md",
