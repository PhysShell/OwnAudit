            {
              "id": "SyntaxTreeCacheAnalyzer",
              "shortDescription": {
                "text": "Controls caching of for example semantic models for syntax trees"
              },
              "fullDescription": {
                "text": "Controls if Semantic models should be cached for syntax trees.\u000d\u000aThis can speed up analysis significantly but means Visual Studio uses more memory during compilation."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "category": "Caching",
                "executionTimeInSeconds": "<0,001",
                "executionTimeInPercentage": "<1"
              }
            },
            {
              "id": "WPF0001",
              "shortDescription": {
                "text": "Backing field for a DependencyProperty should match registered name"
              },
              "fullDescription": {
                "text": "A dependency property's backing field should be named with the name it is registered with suffixed by 'Property'.\u000d\u000aThis is the convention in the framework."
              },
              "helpUri": "https://github.com/DotNetAnalyzers/WpfAnalyzers/tree/master/documentation/WPF0001.md",
